{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "env": {
    "VITE_API_URL": "https://bouncesteps-backend-git-392429231515.europe-west1.run.app/api",
    "VITE_API_BASE_URL": "https://bouncesteps-backend-git-392429231515.europe-west1.run.app/api"
  },
  "redirects": [
    {
      "source": "https://bouncesteps.com/:path*",
      "destination": "https://www.bouncesteps.com/:path*",
      "permanent": true
    },
    {
      "source": "http://bouncesteps.com/:path*",
      "destination": "https://www.bouncesteps.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
